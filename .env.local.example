# ──────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your real values.
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# ──────────────────────────────────────────────────────────────

# Required — Supabase project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Required — anon/public key (Settings → API → Project API keys → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Required for server-side admin operations — service_role key (keep secret, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Site URL used for OAuth + email redirect links
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (future sprint)
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
